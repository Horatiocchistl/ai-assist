# Supabase (required for conversations, projects, and RAG)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Ollama — browser talks directly for chat and embeddings
VITE_OLLAMA_HOST=http://localhost:11434

# Express API (optional; dev uses Vite proxy to :3001, Electron uses same origin)
# VITE_API_URL=http://localhost:3001

# Server-side Ollama (used by /api/models and Docker)
OLLAMA_HOST=http://localhost:11434

# Express listen port
PORT=3001

# Apify — Amazon Product Scraper (junglee/Amazon-crawler)
# Get your token at https://console.apify.com/account/integrations
APIFY_TOKEN=
