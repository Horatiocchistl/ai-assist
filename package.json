{
  "name": "ai-assist",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "bash scripts/start.sh",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server.js",
    "electron:dev": "npm run build && env -u ELECTRON_RUN_AS_NODE electron .",
    "electron:build": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.aiassist.v1",
    "productName": "AI Assist v1",
    "files": [
      "dist/**/*",
      "server.js",
      "skill-dirs.json",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "electron-ollama": "^0.1.25",
    "express": "^4.18.2",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.9.0",
    "lucide-react": "^0.400.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.7.284",
    "playwright": "^1.40.0",
    "portfinder": "^1.0.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^6.3.5"
  }
}
